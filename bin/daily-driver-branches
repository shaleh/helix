#!/usr/bin/env bash
#
# Print the feature branches tracked in changelog.daily-driver, one per
# line, in the order they appear. Each '## <branch-name>' heading is one
# branch. bin/rebuild-daily-driver and bin/sync-feature-branches both read
# the list from here so the parsing lives in exactly one place.
#
# With --mine, drop branches whose name carries a namespace prefix like
# 'someone/fix/thing'. Those come from upstream contributors and aren't
# ours to rebase. Our own branches are bare names with no slash.

set -euo pipefail

MINE_ONLY=false
for arg in "$@"; do
    case "$arg" in
        --mine) MINE_ONLY=true ;;
        -h|--help)
            echo "Usage: bin/daily-driver-branches [--mine]"
            echo "  --mine   only branches without a namespace prefix (no slash)"
            exit 0 ;;
        *) echo "unknown arg: $arg" >&2; exit 2 ;;
    esac
done

ROOT=$(git rev-parse --show-toplevel)
CHANGELOG="$ROOT/changelog.daily-driver"
[[ -f "$CHANGELOG" ]] || { echo "missing $CHANGELOG" >&2; exit 1; }

branches=$(grep -E '^## [^[:space:]]+$' "$CHANGELOG" | sed 's/^## //')

if [[ "$MINE_ONLY" == true ]]; then
    branches=$(printf '%s\n' "$branches" | grep -v '/' || true)
fi

if [[ -z "$branches" ]]; then
    echo "no '## <branch>' entries in $CHANGELOG" >&2
    exit 1
fi

printf '%s\n' "$branches"
